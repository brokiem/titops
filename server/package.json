{
	"name": "server",
	"private": true,
	"version": "0.0.1",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"dev": "bun --watch run src/server.ts",
		"start": "bun run src/server.ts",
		"type-check": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push"
	},
 "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.14",
    "mysql2": "^3.22.2",
    "shared": "workspace:*",
    "zod": "^4.3.6",
    "vite": "^8.0.9"
  },
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"bun-types": "^1.3.13",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"globals": "^17.5.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0"
	}
}
