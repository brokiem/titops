{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["bun-types", "node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
