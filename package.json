{
  "name": "project-titops",
  "version": "1.0.0",
  "description": "A monorepo template built with Bun, Hono, Vite, and React",
  "author": "brokiem",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "./server",
    "./client",
    "./shared"
  ],
  "scripts": {
    "dev:client": "bun run --filter client dev",
    "dev:server": "bun run --filter server dev",
    "start-server": "bun run --filter server start",
    "build-client": "bun run --filter client build",
    "type-check": "bun run --filter server type-check"
  },
  "keywords": [
    "bun",
    "hono",
    "react",
    "vite",
    "monorepo"
  ],
  "devDependencies": {
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.7.3"
  }
}
